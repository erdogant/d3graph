<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ title }}</title>

    {{ SUPPORT }}

    <style type="text/css">
        {% include "style.css" %}
    </style>
</head>
<body style="background-color: {{ background_color }};{% if dark_mode %} color: #eee;{% endif %}"{% if dark_mode %} class="dark-mode"{% endif %}>

<!-- Top row: edge-threshold slider (centered) + top-panel buttons (right) -->
{% if show_controls %}
<div class="header-row">
    {% if max_slider > min_slider %}
    {{ slider_comment_start }}
    <div class="slider-container">
        <form style="margin:0;">
            <span class="slider-label">Edge Threshold: <span id="thresholdValue">{{ SET_SLIDER }}</span></span>
            <span class="slider-label">{{ min_slider }}</span>
            <input type="range" autocomplete="off" id="thresholdSlider" value="{{ min_slider }}" min="{{ min_slider }}" max="{{ max_slider }}" class="styled-slider">
            <span class="slider-label">{{ max_slider }}</span>
        </form>
    </div>
    {{ slider_comment_stop }}
    {% endif %}
<div class="top-panel">
    <button id="darkModeSwitch" class="button-switch">{% if dark_mode %}☀ Light Mode{% else %}🌙 Dark Mode{% endif %}</button>
    <button id="edgeToggleButton" class="button-switch">Hide Edges</button>
    <button id="densityToggleButton" class="button-switch">{% if show_density %}Hide Density{% else %}Show Density{% endif %}</button>
    <button id="exportDataButton" class="button-switch">Export Data</button>
    {% if save_button %}<button id="saveButton" class="button-switch">Save</button>{% endif %}
</div>
</div>

<!-- Side panel: interactively recolor/resize nodes by common network statistics -->
<div class="stats-panel" id="statsPanel">
    <div class="stats-panel-title">Network Statistic<span class="stats-panel-toggle" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></span></div>
    <div class="stats-panel-body">
    <label><input type="radio" name="statMetric" value="user_default" checked> Default</label>
    <label><input type="radio" name="statMetric" value="node_pagerank"> PageRank</label>
    <label><input type="radio" name="statMetric" value="node_hits_hub"> HITS (Hub)</label>
    <label><input type="radio" name="statMetric" value="node_hits_authority"> HITS (Authority)</label>
    <label><input type="radio" name="statMetric" value="node_degree_centrality"> Degree Centrality</label>
    <label><input type="radio" name="statMetric" value="node_closeness_centrality"> Closeness Centrality</label>
    <label><input type="radio" name="statMetric" value="node_betweenness_centrality"> Betweenness Centrality</label>
    <label><input type="radio" name="statMetric" value="network_clustering"> Network Clustering</label>
    </div>
</div>

<!-- Layout panel (Force-directed / Circular / Grid) removed from the UI -
     circular/grid felt too static to be useful. The underlying setLayout()/
     layoutCircular()/layoutGrid() functions are still in d3graphscript.js,
     just unwired, in case this is worth revisiting later. -->

<!-- Side panel: interactively tune the force simulation -->
<div class="stats-panel" id="physicsPanel">
    <div class="stats-panel-title">Physics<span class="stats-panel-toggle" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></span></div>
    <div class="stats-panel-body">
    <div class="physics-control">
        <label for="chargeSlider">Network Tension <span id="chargeValue">{{ charge }}</span></label>
        <input type="range" id="chargeSlider" min="-2000" max="200" step="10" value="{{ charge }}">
    </div>
    <div class="physics-control">
        <label for="collisionSlider">Collision <span id="collisionValue">{{ collision }}</span></label>
        <input type="range" id="collisionSlider" min="0" max="2" step="0.05" value="{{ collision }}">
    </div>
    <div class="physics-control">
        <label for="linkTensionSlider">Edge Tension <span id="linkTensionValue">{{ link_tension }}</span></label>
        <input type="range" id="linkTensionSlider" min="0" max="5" step="0.1" value="{{ link_tension }}">
    </div>
    <button id="physicsResetButton" class="button-switch">Reset to Default</button>
    </div>
</div>

<!-- Side panel: interactively tune the density heatmap layer -->
<div class="stats-panel" id="densityPanel">
    <div class="stats-panel-title">Density Layer<span class="stats-panel-toggle" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></span></div>
    <div class="stats-panel-body">
    <div class="physics-control">
        <label for="densityGridSizeSlider">Grid Size <span id="densityGridSizeValue">{{ density_grid_size }}</span></label>
        <input type="range" id="densityGridSizeSlider" min="5" max="120" step="5" value="{{ density_grid_size }}">
    </div>
    <div class="physics-control">
        <label for="densityBlurSlider">Blur <span id="densityBlurValue">{{ density_blur }}</span></label>
        <input type="range" id="densityBlurSlider" min="0" max="30" step="1" value="{{ density_blur }}">
    </div>
    <div class="physics-control">
        <label for="densityOpacitySlider">Opacity <span id="densityOpacityValue">{{ density_opacity }}</span></label>
        <input type="range" id="densityOpacitySlider" min="0" max="1" step="0.05" value="{{ density_opacity }}">
    </div>
    <button id="densityResetButton" class="button-switch">Reset to Default</button>
    </div>
</div>

<!-- Side panel: details for whichever node is currently selected, with browser-style back/forward navigation through previously viewed nodes -->
<div class="stats-panel" id="nodeInfoPanel">
    <div class="stats-panel-title">Node Info<span class="stats-panel-toggle" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></span></div>
    <div class="stats-panel-body">
    <div class="node-info-nav">
        <button type="button" id="nodeInfoBack" class="node-info-nav-btn" title="Back" disabled>&larr;</button>
        <button type="button" id="nodeInfoForward" class="node-info-nav-btn" title="Forward" disabled>&rarr;</button>
    </div>
    <div id="nodeInfoContent" class="node-info-content">
        <div class="node-info-placeholder">Click a node to see its details.</div>
    </div>
    </div>
</div>


{% endif %}


    <script>
        {% include "d3.v3.js" %}
        {% include "d3graphscript.js" %}

        graph = {{ json_data }}

        window.addEventListener('DOMContentLoaded', function () {
            d3graphscript({
                width: {{ width }},
                height: {{ height }},
                charge: {{ charge }},
                distance: {{ edge_distance }},
                directed: {{ directed | lower }},
                collision: {{ collision }},
                link_tension: {{ link_tension }},
                sticky: {{ sticky | lower }},
                background_color: '{{ background_color }}',
                node_text_inside: {{ node_text_inside | lower }},
                max_ticks: {{ max_ticks }},
                canvas_edge_threshold: {{ canvas_edge_threshold }},
                label_zoom_threshold: {{ label_zoom_threshold }},
                density_grid_size: {{ density_grid_size }},
                density_blur: {{ density_blur }},
                density_opacity: {{ density_opacity }},
                show_density: {{ show_density | lower }},
                dark_mode: {{ 'true' if dark_mode else 'false' }},
            })
            positionSidePanels();
        });

        // Stacks every .stats-panel element (Network Statistic, Layout, ...)
        // below the header row (edge-threshold slider + top-panel buttons),
        // using its actual measured height rather than a hardcoded pixel
        // guess ÃƒÂ¢Ã¢â€šÂ¬Ã¢â‚¬Â a guessed offset breaks the moment the row wraps onto two
        // lines on a narrower screen, which is exactly what caused this
        // panel's earlier positioning bugs. Scales to any number of panels
        // automatically. Falls back to .top-panel alone if .header-row isn't
        // present (e.g. no edge-threshold slider to show).
        function positionSidePanels() {
            var headerRow = document.querySelector('.header-row') || document.querySelector('.top-panel');
            var panels = document.querySelectorAll('.stats-panel');
            if (!headerRow || !panels.length) return;
            var y = headerRow.getBoundingClientRect().bottom + 8;
            panels.forEach(function (panel) {
                panel.style.top = y + 'px';
                panel.style.left = '10px';
                // A flat "calc(100vh - 40px)" (the CSS fallback) ignores how
                // far down the stack this particular panel sits, so a panel
                // near the bottom (Node Info is last) could grow past the
                // bottom of the screen â€” taking its resize handle with it,
                // with no way to grab it back. Cap each panel's max-height to
                // whatever viewport space actually remains below its own top.
                panel.style.maxHeight = 'calc(100vh - ' + Math.round(y + 10) + 'px)';
                y += panel.getBoundingClientRect().height + 8;
            });
        }
        window.addEventListener('resize', positionSidePanels);

        // NEW: Reposition immediately whenever a panel is resized.
        if (window.ResizeObserver) {
            const panelObserver = new ResizeObserver(function() {
                positionSidePanels();
            });
            document.querySelectorAll('.stats-panel').forEach(function(panel) {
                panelObserver.observe(panel);
            });
        }


        // Collapsible side panels: clicking a panel's title hides/shows its
        // body (everything but the title) and flips the arrow. Re-stacks
        // immediately after, since positionSidePanels() measures each
        // panel's actual rendered height Ã¢â‚¬â€ a collapsed panel is just
        // shorter, no separate logic needed to close the gap.
        document.querySelectorAll('.stats-panel-title').forEach(function (title) {
            title.addEventListener('click', function () {
                var panel = title.parentElement;
                var collapsing = !panel.classList.contains('collapsed');
                if (collapsing) {
                    // Dragging the native resize handle sets an inline
                    // height on the panel. That inline height sticks around
                    // even after the body is hidden via the .collapsed CSS
                    // class, so a manually-resized panel would just show a
                    // tall block of empty space instead of actually
                    // shrinking â€” looking like the collapse button had
                    // stopped working. Remember it, then clear it so the
                    // panel really collapses down to the title bar.
                    if (panel.style.height) {
                        panel.dataset.expandedHeight = panel.style.height;
                    }
                    panel.style.height = '';
                } else if (panel.dataset.expandedHeight) {
                    // Restore whatever size the user had manually set.
                    panel.style.height = panel.dataset.expandedHeight;
                }
                panel.classList.toggle('collapsed');
                positionSidePanels();
            });
        });

        // Dark mode toggle logic
        const darkSwitch = document.getElementById('darkModeSwitch');
        let darkMode = {{ 'true' if dark_mode else 'false' }};
        let originalBg = document.body.style.backgroundColor;
        function setDarkMode(on) {
            if (on) {
                document.body.classList.add('dark-mode');
                document.body.style.backgroundColor = '#222';
                document.body.style.color = '#eee';
                let graphBg = document.getElementById('graphContainer');
                if (graphBg) graphBg.style.backgroundColor = '#222';
                if (darkSwitch) darkSwitch.textContent = '☀ Light Mode';
            } else {
                document.body.classList.remove('dark-mode');
                document.body.style.backgroundColor = originalBg;
                document.body.style.color = '';
                let graphBg = document.getElementById('graphContainer');
                if (graphBg) graphBg.style.backgroundColor = originalBg;
                if (darkSwitch) darkSwitch.textContent = '🌙 Dark Mode';
            }
            if (window.d3graphSetDarkMode) window.d3graphSetDarkMode(on);
        }
        // Set initial mode
        setDarkMode(darkMode);
        if (darkSwitch) {
            darkSwitch.addEventListener('click', function () {
                darkMode = !darkMode;
                setDarkMode(darkMode);
            });
        }

        // Save image to svg
        // Note: when the graph is large enough to switch to canvas-rendered edges
        // (see canvas_edge_threshold), this export will include nodes but not edges,
        // since edges live on a separate <canvas> element, not in the SVG DOM.
        var saveBtn = document.getElementById('saveButton');
        if (saveBtn) {
            saveBtn.addEventListener('click', function () {
            var svgData = document.querySelector('svg').outerHTML;
            var blob = new Blob([svgData], {type: "image/svg+xml;charset=utf-8"});
            var url = URL.createObjectURL(blob);
            var link = document.createElement('a');
            link.href = url;
            link.download = '{{ title }}.svg';
            link.click();
            });
        }
        
        
    </script>



</body>
</html>

