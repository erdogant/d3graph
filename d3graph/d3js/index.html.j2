<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ title }}</title>

    {{ SUPPORT }}

    <style type="text/css">
        {% include "style.css" %}
    </style>
</head>
<body style="background-color: {{ background_color }};{% if dark_mode %} color: #eee;{% endif %}"{% if dark_mode %} class="dark-mode"{% endif %}>

<!-- Top right panel with dark mode and save buttons -->
{% if show_controls %}
<div class="top-panel">
    <button id="darkModeSwitch" class="button-switch">{% if dark_mode %}☀ Light Mode{% else %}🌙 Dark Mode{% endif %}</button>
    <button id="edgeToggleButton" class="button-switch">Hide Edges</button>
    <button id="densityToggleButton" class="button-switch">{% if show_density %}Hide Density{% else %}Show Density{% endif %}</button>
    <button id="exportDataButton" class="button-switch">Export Data</button>
    {% if save_button %}<button id="saveButton" class="button-switch">Save</button>{% endif %}
</div>
1
<!-- Side panel: interactively recolor/resize nodes by common network statistics -->
<div class="stats-panel" id="statsPanel">
    <div class="stats-panel-title">Network Statistic</div>
    <label><input type="radio" name="statMetric" value="none" checked> Default</label>
    <label><input type="radio" name="statMetric" value="node_pagerank"> PageRank</label>
    <label><input type="radio" name="statMetric" value="node_hits_hub"> HITS (Hub)</label>
    <label><input type="radio" name="statMetric" value="node_hits_authority"> HITS (Authority)</label>
    <label><input type="radio" name="statMetric" value="node_degree_centrality"> Degree Centrality</label>
    <label><input type="radio" name="statMetric" value="node_closeness_centrality"> Closeness Centrality</label>
    <label><input type="radio" name="statMetric" value="node_betweenness_centrality"> Betweenness Centrality</label>
</div>
{% endif %}

    <script>
        {% include "d3.v3.js" %}
        {% include "d3graphscript.js" %}

        graph = {{ json_data }}

        window.addEventListener('DOMContentLoaded', function () {
            d3graphscript({
                width: {{ width }},
                height: {{ height }},
                charge: {{ charge }},
                distance: {{ edge_distance }},
                directed: {{ directed | lower }},
                collision: {{ collision }},
                link_tension: {{ link_tension }},
                sticky: {{ sticky | lower }},
                background_color: '{{ background_color }}',
                node_text_inside: {{ node_text_inside | lower }},
                max_ticks: {{ max_ticks }},
                canvas_edge_threshold: {{ canvas_edge_threshold }},
                label_zoom_threshold: {{ label_zoom_threshold }},
                density_grid_size: {{ density_grid_size }},
                density_blur: {{ density_blur }},
                density_opacity: {{ density_opacity }},
                show_density: {{ show_density | lower }},
                dark_mode: {{ 'true' if dark_mode else 'false' }},
            })
        });

        // Dark mode toggle logic
        const darkSwitch = document.getElementById('darkModeSwitch');
        let darkMode = {{ 'true' if dark_mode else 'false' }};
        let originalBg = document.body.style.backgroundColor;
        function setDarkMode(on) {
            if (on) {
                document.body.classList.add('dark-mode');
                document.body.style.backgroundColor = '#222';
                document.body.style.color = '#eee';
                let graphBg = document.getElementById('graphContainer');
                if (graphBg) graphBg.style.backgroundColor = '#222';
                if (darkSwitch) darkSwitch.textContent = '☀ Light Mode';
            } else {
                document.body.classList.remove('dark-mode');
                document.body.style.backgroundColor = originalBg;
                document.body.style.color = '';
                let graphBg = document.getElementById('graphContainer');
                if (graphBg) graphBg.style.backgroundColor = originalBg;
                if (darkSwitch) darkSwitch.textContent = '🌙 Dark Mode';
            }
            if (window.d3graphSetDarkMode) window.d3graphSetDarkMode(on);
        }
        // Set initial mode
        setDarkMode(darkMode);
        if (darkSwitch) {
            darkSwitch.addEventListener('click', function () {
                darkMode = !darkMode;
                setDarkMode(darkMode);
            });
        }

        // Save image to svg
        // Note: when the graph is large enough to switch to canvas-rendered edges
        // (see canvas_edge_threshold), this export will include nodes but not edges,
        // since edges live on a separate <canvas> element, not in the SVG DOM.
        var saveBtn = document.getElementById('saveButton');
        if (saveBtn) {
            saveBtn.addEventListener('click', function () {
            var svgData = document.querySelector('svg').outerHTML;
            var blob = new Blob([svgData], {type: "image/svg+xml;charset=utf-8"});
            var url = URL.createObjectURL(blob);
            var link = document.createElement('a');
            link.href = url;
            link.download = '{{ title }}.svg';
            link.click();
            });
        }
        
        
    </script>



<!-- SLIDER -->
{{ slider_comment_start }}

    {% if max_slider > min_slider %}
	<div style="max-width:{{ width }}px;" class="slider-container">
        <form style="margin:0;">
            <span class="slider-label">Edge Threshold</span>
            <span class="slider-label">{{ min_slider }}</span>
            <input type="range" autocomplete="off" id="thresholdSlider" value="{{ min_slider }}" min="{{ min_slider }}" max="{{ max_slider }}" class="styled-slider">
            <span class="slider-label">{{ max_slider }}</span>
        </form>
	</div>
    {% endif %}

{{ slider_comment_stop }}

</body>
</html>

